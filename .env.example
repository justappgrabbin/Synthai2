# ═══════════════════════════════════════════════════════════════════════════════
#  SYNTHIA OS — .env.example
#  Copy to .env and fill in values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Ports (host-side) ─────────────────────────────────────────────────────────
STUDIO_PORT=5000        # Studio UI
SYNTHIA_PORT=10000      # Synthia Node API + WebSocket

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=production
NODE_MODE=full          # full | lite

# ── Supabase (Aion substrate mesh persistence) ────────────────────────────────
# Project ID: leisphnjslcuepflefri
SUPABASE_PRIMARY_URL=https://leisphnjslcuepflefri.supabase.co
SUPABASE_PRIMARY_KEY=                  # ← required for mesh persistence
SUPABASE_SECONDARY_URL=
SUPABASE_SECONDARY_KEY=
SUPABASE_APP_BUCKET=synthia-apps

# ── Security ──────────────────────────────────────────────────────────────────
TERMINAL_TOKEN=                        # auto-generated on first boot if blank
CORS_ORIGIN=*

# ── AI Backends ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
KIMI_API_KEY=           # Moonshot moonshot-v1-128k

# ── HuggingFace / Trident ONNX ────────────────────────────────────────────────
HF_TOKEN=
HF_REPO_ID=stellarproximology/Trident
TRIDENT_ONNX_ENABLED=false    # true = load ~1M param ONNX model (needs more RAM)
TRIDENT_MODEL_URL=

# ── IDE Export ────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ACCESS_TOKEN=

# ── Frontend build-time Synthia wiring ───────────────────────────────────────
VITE_SYNTHIA_API_URL=http://localhost:10000
VITE_SYNTHIA_WS_URL=ws://localhost:10000/ws
