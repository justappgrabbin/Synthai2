{
  "name": "synthia-os",
  "version": "2.0.0",
  "description": "Self-modifying ontological operating system",
  "main": "server/lite.js",
  "scripts": {
    "start": "node --max-old-space-size=1024 -r ./server/control-preload.js server/lite.js",
    "start:full": "node --max-old-space-size=1536 server/index.js",
    "start:lite": "node --max-old-space-size=1024 -r ./server/control-preload.js server/lite.js",
    "dev": "nodemon server/index.js",
    "dev:lite": "nodemon -r ./server/control-preload.js server/lite.js",
    "test": "node test/deploy.test.js",
    "mcp": "tsx trident-mcp-server.ts",
    "youniverse:start": "tsx server/you-n-i-verse/index.ts",
    "youniverse:dev": "tsx watch server/you-n-i-verse/index.ts",
    "trident:mcp": "python trident/mcp_server.py",
    "trident:http": "uvicorn trident.mcp_server:app --host 0.0.0.0 --port ${TRIDENT_PORT:-8000}",
    "trident:signal": "python trident/signal_server.py",
    "init:roots": "node server/scripts/init-roots.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.9.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "onnxruntime-node": "^1.16.0",
    "pdf-parse": "^1.1.1",
    "simple-git": "^3.20.0",
    "socket.io": "^4.7.5",
    "tsx": "^4.19.2",
    "ws": "^8.14.2",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": "24.x"
  }
}